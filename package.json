{
  "name": "@william5553/translate-google-api",
  "version": "4.0.1",
  "description": "A dependency-free, fully typed client for Google Translate",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "validate": "bun run lint && bun run check && bun run test && bun run build",
    "prepublishOnly": "bun run validate"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "keywords": [
    "google",
    "translate",
    "googletranslate",
    "google-translate",
    "typescript"
  ],
  "repository": "github:wkangg/translate-google-api",
  "author": "William Kang <william@wkang.ca>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wkangg/translate-google-api/issues"
  },
  "homepage": "https://github.com/wkangg/translate-google-api",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
